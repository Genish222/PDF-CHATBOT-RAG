# -----------------------------------------------------------------------------
# Google Gemini
# -----------------------------------------------------------------------------

# Required: Google Gemini API key
GOOGLE_API_KEY=your_google_api_key_here

# LLM model for chat completion
MODEL_NAME=gemini-2.0-flash

# Embedding model for vector indexing
EMBEDDING_MODEL=models/embedding-001

# -----------------------------------------------------------------------------
# RAG
# -----------------------------------------------------------------------------

# Text splitting (characters)
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# Directory for persisted FAISS vector store
VECTOR_STORE_PATH=data/vectorstores

# Directory for uploaded PDF files
UPLOAD_PATH=data/uploads

# Maximum PDF upload size in bytes (default: 10485760 = 10 MiB)
MAX_FILE_SIZE=10485760

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Supported values: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
